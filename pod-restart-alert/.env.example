# Krateo Alert Bootstrap Configuration
# Copy to .env and fill in your values:
#   cp .env.example .env

# HyperDX base URL (e.g. http://localhost:3000 when port-forwarding)
HYPERDX_URL=http://localhost:3000

# Personal API key from HyperDX (Settings → API Keys)
HYPERDX_API_KEY=

# Webhook ID for human-visible alerts (create in HyperDX UI: Alerts → Integrations)
WEBHOOK_ID=

# Webhook ID for agent-routed alerts (via autopilot-alert-proxy)
# Defaults to WEBHOOK_ID if not set
ALERT_PROXY_WEBHOOK_ID=

# Saved Search ID — only needed for bootstrap-alert.sh (single alert)
# bootstrap-all-alerts.sh creates saved searches automatically
SAVED_SEARCH_ID=

# Optional: Slack user ID to @mention the KAgent bot (e.g. <@U0ABC123>)
KRATEO_BOT_MENTION=
