# Pod Restart Alert – HyperDX API Bootstrap
# Copy to .env and fill in your values:
#   cp .env.example .env

# HyperDX base URL (e.g. http://localhost:3000 when port-forwarding)
HYPERDX_URL=http://localhost:3000

# Personal API key from HyperDX (Settings → API Keys)
HYPERDX_API_KEY=

# Webhook ID – create in HyperDX UI: Alerts → Integrations → Webhooks
# Target: #krateo-troubleshooting in aiagents-gruppo
WEBHOOK_ID=

# Saved Search ID – create in HyperDX UI: Search → save "Pod Restart Events"
SAVED_SEARCH_ID=

# Optional: Slack user ID to @mention the KAgent bot (e.g. <@U0ABC123>)
KRATEO_BOT_MENTION=
