<!--
  ClickHouse HTTP Handler Configuration
  =====================================
  Exposes K8s events directly from otel_logs via a predefined_query_handler.

  IMPORTANT: When <http_handlers> is present in config.d, it is merged with the
  main config (which has no <http_handlers>). Built-in hardcoded handlers
  (/ping, /replicas_status, /play, etc.) remain available as fallbacks.

  Endpoint: GET /events?composition_id=<uid>[&limit=50]
  Returns:  FORMAT JSON rows; transformed into SSEK8sEvent by the RESTAction
            JQ filter in restaction.composition-events.yaml.
  Mount at: /etc/clickhouse-server/config.d/http-handlers.xml

  NOTE: Uses query-parameter style (?composition_id=...) rather than path
  parameters (/events/{id}) to avoid CDATA/regex angle-bracket parsing issues
  in ClickHouse's XML config merger.
-->
<clickhouse>
  <http_handlers>

    <!-- ================================================================
         Custom: Krateo K8s events endpoint
         GET /events?composition_id=<uid>[&limit=50]
         {composition_id:String} is the composition resource's UID,
         matching the value of label krateo.io/composition-id on managed
         resources.

         The compositionresolver OTel processor enriches each K8s event
         log record with a LogAttribute "krateo.io/composition-id" by
         resolving the involvedObject via the K8s API — the same logic
         the old EventRouter performed.

         Event fields are extracted from the raw K8s watch JSON in Body
         using JSONExtractString.
         ================================================================ -->
    <rule>
      <url>/events</url>
      <methods>GET</methods>
      <handler>
        <type>predefined_query_handler</type>
        <query>
          SELECT
              ifNull(JSONExtractString(Body, 'object', 'involvedObject', 'name'), '')      AS obj_name,
              ifNull(JSONExtractString(Body, 'object', 'involvedObject', 'namespace'), '') AS obj_namespace,
              ifNull(JSONExtractString(Body, 'object', 'involvedObject', 'uid'), '')       AS obj_uid,
              ifNull(JSONExtractString(Body, 'object', 'involvedObject', 'kind'), '')      AS obj_kind,
              ifNull(JSONExtractString(Body, 'object', 'reason'), '')                      AS reason,
              ifNull(JSONExtractString(Body, 'object', 'message'), '')                     AS message,
              ifNull(JSONExtractString(Body, 'object', 'type'), 'Normal')                  AS type,
              coalesce(
                  nullIf(JSONExtractString(Body, 'object', 'eventTime'), ''),
                  nullIf(JSONExtractString(Body, 'object', 'lastTimestamp'), ''),
                  formatDateTime(toDateTime(Timestamp), '%Y-%m-%dT%H:%i:%SZ', 'UTC')
              )                                                                             AS eventTime,
              ifNull(JSONExtractString(Body, 'object', 'source', 'component'), '')         AS source_component
          FROM otel_logs
          WHERE ResourceAttributes['telemetry.source'] = 'k8s-events'
            AND LogAttributes['krateo.io/composition-id'] = {composition_id:String}
            AND JSONExtractString(Body, 'object', 'reason') != ''
          ORDER BY Timestamp DESC
          LIMIT 50
          FORMAT JSON
        </query>
      </handler>
    </rule>

    <!-- /ping – preserve for Kubernetes startup/liveness probe -->
    <rule>
      <url>/ping</url>
      <handler>
        <type>static</type>
        <status>200</status>
        <content_type>text/plain; charset=UTF-8</content_type>
        <response_content>Ok.
</response_content>
      </handler>
    </rule>

    <!-- /replicas_status – cluster health -->
    <rule>
      <url>/replicas_status</url>
      <handler>
        <type>replicas_status</type>
      </handler>
    </rule>

    <!-- /metrics – Prometheus scrape -->
    <rule>
      <url>/metrics</url>
      <handler>
        <type>prometheus</type>
      </handler>
    </rule>

    <!-- Default query handler at root path – required by clickhouse_connect and
         any client using GET/POST /?query=... (must have explicit url to avoid
         the bad_function_call crash in ClickHouse 25.7 with no-url catch-alls) -->
    <rule>
      <url>/</url>
      <methods>GET,POST</methods>
      <handler>
        <type>dynamic_query_handler</type>
        <query_param_name>query</query_param_name>
      </handler>
    </rule>

  </http_handlers>
</clickhouse>
